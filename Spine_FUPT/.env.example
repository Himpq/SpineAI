# Flask secret key for session signing
FLASK_SECRET_KEY=your-random-secret-key-here

# StepFun LLM API key
STEPFUN_API_KEY=your-stepfun-api-key-here

# Remote inference server URL (optional, defaults to http://spine.healthit.cn:15443)
# SPINE_REMOTE_INFER_BASE=http://localhost:8000

# Remote inference timeout in seconds (optional, default 60)
# SPINE_REMOTE_TIMEOUT=60
